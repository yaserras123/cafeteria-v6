{
  "version": 2,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "dist/client",
  "installCommand": "pnpm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
