{
  "version": 2,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ]
}
