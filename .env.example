# ============================================================================
# CAFETERIA V6 - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env with real secrets to version control

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL / Supabase)
# ============================================================================
# For local development:
# DATABASE_URL=postgresql://username:password@localhost:5432/cafeteria_db

# For Supabase (production):
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# ============================================================================
# AUTHENTICATION
# ============================================================================
# JWT Secret for token signing (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# OAuth Configuration
VITE_APP_ID=your_app_id_here
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=owner_reference_code_10

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# OPTIONAL: AWS S3 FOR IMAGE UPLOADS
# ============================================================================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name

# ============================================================================
# OPTIONAL: REDIS FOR REAL-TIME UPDATES & CACHING
# ============================================================================
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# ============================================================================
# OPTIONAL: LOGGING & MONITORING
# ============================================================================
# LOG_LEVEL=info
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# FEATURES
# ============================================================================
# Enable/disable features
ENABLE_SPLIT_BILL=true
ENABLE_PARTIAL_PAYMENTS=true
ENABLE_WAITER_ESCALATION=true
ENABLE_CHEF_ROUTING=true
ENABLE_KITCHEN_LOCK=true
ENABLE_REALTIME_UPDATES=true

# Waiter escalation timeout (seconds)
WAITER_ESCALATION_TIMEOUT=60

# ============================================================================
# DEPLOYMENT
# ============================================================================
# For Vercel deployment:
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app

# ============================================================================
# NOTES
# ============================================================================
# 1. Generate JWT_SECRET: openssl rand -base64 32
# 2. Get DATABASE_URL from Supabase dashboard
# 3. Configure OAuth with your provider
# 4. For production, use strong passwords and secure keys
# 5. Never commit .env file to version control
# 6. Use environment variables in CI/CD pipelines
