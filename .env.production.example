# ============================================================================
# CAFETERIA V6 - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# This file documents all required and optional environment variables for
# production deployment on Vercel + Supabase + GitHub
#
# Copy this file to .env.production and fill in your actual values
# IMPORTANT: Never commit .env.production with real secrets to version control

# ============================================================================
# DATABASE CONFIGURATION (Supabase PostgreSQL)
# ============================================================================
# Get this from Supabase Dashboard → Settings → Database
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# ============================================================================
# AUTHENTICATION (JWT & OAuth)
# ============================================================================
# JWT Secret for signing tokens
# Generate with: openssl rand -base64 32
# CRITICAL: Use a strong, unique value. Rotate every 90 days
JWT_SECRET=your_jwt_secret_key_here_min_32_chars_strong_random

# OAuth Configuration (Manus OAuth or your provider)
VITE_APP_ID=your_production_app_id
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=10

# ============================================================================
# ENVIRONMENT & DEPLOYMENT
# ============================================================================
NODE_ENV=production
PORT=3000

# Vercel Deployment
VERCEL_ENV=production
VERCEL_URL=your-app.vercel.app

# ============================================================================
# OPTIONAL: AWS S3 FOR IMAGE UPLOADS
# ============================================================================
# Enable image uploads to S3 (optional but recommended)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-cafeteria-bucket

# ============================================================================
# OPTIONAL: REDIS FOR REAL-TIME UPDATES & CACHING
# ============================================================================
# For real-time features and caching (optional)
# REDIS_URL=redis://:[PASSWORD]@your-redis-host:6379
# REDIS_PASSWORD=your_redis_password

# ============================================================================
# OPTIONAL: MONITORING & LOGGING
# ============================================================================
# Sentry for error tracking (optional)
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features (V6 additions)
ENABLE_SPLIT_BILL=true
ENABLE_PARTIAL_PAYMENTS=true
ENABLE_WAITER_ESCALATION=true
ENABLE_CHEF_ROUTING=true
ENABLE_KITCHEN_LOCK=true
ENABLE_REALTIME_UPDATES=true

# Waiter escalation timeout in seconds (default: 60)
WAITER_ESCALATION_TIMEOUT=60

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================
# Umami Analytics (optional)
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=your_website_id

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production:
#
# 1. Database:
#    ✓ Create Supabase project
#    ✓ Get DATABASE_URL from Supabase Dashboard
#    ✓ Run migrations: pnpm run db:migrate
#    ✓ Verify schema with: pnpm run db:push
#
# 2. Authentication:
#    ✓ Generate JWT_SECRET: openssl rand -base64 32
#    ✓ Configure OAuth provider
#    ✓ Set VITE_APP_ID and OAUTH_SERVER_URL
#    ✓ Set OWNER_OPEN_ID (reference code for owner account)
#
# 3. Deployment:
#    ✓ Connect GitHub repository to Vercel
#    ✓ Add environment variables in Vercel Settings
#    ✓ Set different values for Production/Preview/Development
#    ✓ Enable automatic deployments from main branch
#
# 4. Security:
#    ✓ Enable HTTPS (automatic with Vercel)
#    ✓ Set up CORS properly
#    ✓ Configure rate limiting
#    ✓ Enable database SSL/TLS
#
# 5. Monitoring:
#    ✓ Set up Sentry for error tracking
#    ✓ Configure logging
#    ✓ Set up uptime monitoring
#    ✓ Configure alerts for critical errors
#
# 6. Backup:
#    ✓ Enable Supabase automated backups
#    ✓ Test restore procedure
#    ✓ Document backup schedule

# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================
#
# 1. Secret Rotation:
#    - Rotate JWT_SECRET every 90 days
#    - Rotate database password every 90 days
#    - Rotate AWS keys every 90 days
#
# 2. Access Control:
#    - Use separate credentials per environment
#    - Enable database SSL/TLS
#    - Use IAM roles for AWS access
#    - Restrict database network access
#
# 3. Monitoring:
#    - Monitor failed authentication attempts
#    - Alert on unusual API usage
#    - Track database connection errors
#    - Review access logs regularly
#
# 4. Incident Response:
#    - Document incident response procedure
#    - Have rollback plan ready
#    - Test disaster recovery regularly
#    - Maintain audit logs

# ============================================================================
# REFERENCES
# ============================================================================
# - Supabase Docs: https://supabase.com/docs
# - Vercel Docs: https://vercel.com/docs
# - Node.js Security: https://nodejs.org/en/docs/guides/security/
# - OWASP Secrets Management: https://cheatsheetseries.owasp.org/cheatsheets/Secrets_Management_Cheat_Sheet.html
